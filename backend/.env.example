# TRIBASION NODE.JS BACKEND ENVIRONMENT VARIABLES

# Environment mode ('development' or 'production')
NODE_ENV=production

# The port the backend server runs on
PORT=5000

# Security secret for JWT tokens
JWT_SECRET=your_super_secret_jwt_key

# The exact URL of the Vercel frontend site to allow across cors checks
FRONTEND_URL=https://tribastion.vercel.app

# The URL for the python microservice (use http://127.0.0.1:5001 if hosted together on Render using the unified Dockerfile)
PII_SERVICE_URL=http://127.0.0.1:5001
